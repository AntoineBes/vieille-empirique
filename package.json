{
  "name": "veille-empirique",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "prisma:migrate": "prisma migrate deploy",
    "sync:insee": "tsx src/scripts/run-connector.ts insee",
    "sync:legifrance": "tsx src/scripts/run-connector.ts legifrance",
    "sync:bdf": "tsx src/scripts/run-connector.ts banque-de-france",
    "sync:datagouv": "tsx src/scripts/run-connector.ts datagouv",
    "sync:ocde": "tsx src/scripts/run-connector.ts ocde",
    "sync:all": "tsx src/scripts/run-connector.ts all",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "generate:docs": "tsx src/scripts/generate-docs.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "docx": "^9.0.2",
    "next": "^14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10",
    "postcss": "^8",
    "prisma": "^5.10.0",
    "tailwindcss": "^3",
    "tsx": "^4.7.0",
    "typescript": "^5",
    "vitest": "^2.1.0"
  }
}
